{
  "name": "dprint",
  "version": "0.54.0",
  "description": "Pluggable and configurable code formatting platform written in Rust.",
  "bin": "bin.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dprint/dprint.git"
  },
  "keywords": [
    "code",
    "formatter"
  ],
