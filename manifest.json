{
  "manifest_version": 3,
  "name": "Pretty JSON",
  "version": "1.0.0",
  "description": "High-performance streaming JSON pretty-printer. Auto-formats JSON <pre> blocks on any page.",
  "icons": {
    "16": "icons/logo-16.png",
    "32": "icons/logo-32.png",
    "48": "icons/logo-48.png",
    "128": "icons/logo-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/index.js",
        "src/client.js",
        "src/worker.js",
        "src/formatter.js",
        "src/chunker.js",
        "src/constants.js",
        "themes/fonts/JetBrainsMono-Regular.woff2"
      ],
      "matches": ["<all_urls>", "file:///*"]
    }
  ]
}
